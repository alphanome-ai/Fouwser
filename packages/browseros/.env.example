# Windows Code Signing
# Provider: 'ssl' (SSL.com eSigner) or 'azure' (Azure Trusted Signing)
WINDOWS_SIGN_PROVIDER=ssl

# --- SSL.com eSigner (when WINDOWS_SIGN_PROVIDER=ssl) ---
ESIGNER_USERNAME=
ESIGNER_PASSWORD=
# TOTP secret (QR code secret) for 2FA
ESIGNER_TOTP_SECRET=
ESIGNER_CREDENTIAL_ID=
CODE_SIGN_TOOL_PATH=C:/src/CodeSignTool-v1.3.2-windows

# --- Azure Trusted Signing (when WINDOWS_SIGN_PROVIDER=azure) ---
# Required:
AZURE_SIGN_ENDPOINT=
AZURE_SIGN_ACCOUNT=
AZURE_SIGN_CERT_PROFILE=
AZURE_SIGN_DLIB_PATH=
# Optional (for CI/service principal auth; omit for local dev using `az login`):
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# macOS Code Signing
MACOS_CERTIFICATE_NAME=
PROD_MACOS_NOTARIZATION_APPLE_ID=
PROD_MACOS_NOTARIZATION_TEAM_ID=
PROD_MACOS_NOTARIZATION_PWD=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
CLOUDFLARE_API_TOKEN=
R2_BUCKET=browseros
R2_CDN_BASE_URL=http://cdn.browseros.com

# Slack Notifications
SLACK_WEBHOOK_URL=

# Sparkle Signing (macOS only)
SPARKLE_PRIVATE_KEY=
# Path to sign_update tool
SPARKLE_SIGN_UPDATE_PATH=

# Optional
# CHROMIUM_SRC=C:/src/chromium/src
# DEPOT_TOOLS_WIN_TOOLCHAIN=0
# CHROME_PACKER=
